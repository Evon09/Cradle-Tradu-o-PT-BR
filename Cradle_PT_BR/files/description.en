													Impresso em 14/08/2058"/>

		<garden_transferer_01_desc		value="Cabine de transferência alternativa<br/><br/>
											Desenvolvedor da tecnologia modificada:<br/>
											Instituto de Neurocampo Relíquia. 2056.<br/><br/>
											Atenção!<br/>
											Siga os procedimentos de segurança.<br/>
											Durante o procedimento, a entrada na cabine é proibida."/>

		<garden_transferer_02_desc		value="Atenção!<br/>
											Faça um «gesto de confirmação» após o sinal sonoro."/>

