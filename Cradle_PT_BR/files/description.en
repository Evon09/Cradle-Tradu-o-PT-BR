		<task_p21_donor_set_synchronizer		value="Instale o novo sincronizador em Ida."/>

		<task_p21_donor_ida_talk		value="Fale com Ida."/>

		<task_p22_batjin_message_overall		value="<font size=24 color=#D29B28>Palavras de Despedida</font><br/><br/>Apenas seus pais podem saber o que conectava Ida e Mark. Encontre seus pertences pessoais.<br/><br/>"/>

		<task_p22_batjin_message_batjin_talk		value="Interrogue Tabaha."/>

		<task_p22_batjin_message_examine_bedside		value="Procure na mesa de cabeceira de Batjin."/>

		<task_p23_letters_overall		value="<font size=24 color=#D29B28>Cartas Estrangeiras</font><br/><br/>Siga as instruções do avô Batjin para abrir os baús de seus pais.<br/><br/>"/>

		<task_p23_letters_set_uv		value="Prenda um acessório na lanterna."/>

		<task_p23_letters_right_question		value="Leia a parábola do livro sob o altar. Encontre o túmulo de Batjin perto da yurt. Use a lanterna e a pista da parábola para encontrar uma chave para os baús."/>

