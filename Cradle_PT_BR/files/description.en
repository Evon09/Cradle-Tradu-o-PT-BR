		<task_cloud_country		value="— Colete 30 cubos amarelos para ganhar a bateria.<br/>
										— Arremesse cubos na corrente ascendente.<br/>
										— Crie plataformas.<br/>
										— Aplique um cubo amarelo em um branco para criar uma plataforma."/>

		<task_p17_form_overall		value="<font size=24 color=#D29B28>Morfofobia</font><br/><br/>A célula de combustível de Ida está quase descarregada e precisa ser substituída.<br/><br/>"/>

		<task_p17_form_set_battery		value="Instale a nova bateria em Ida."/>

		<task_p17_form_talk_ida		value="Fale com Ida."/>

		<task_p18_oldtv_overall		value="<font size=24 color=#D29B28>Notícias Terríveis</font><br/><br/>Ajude Ida a se conectar à Rede. Ligue a energia para o terminal de rede embaixo da TV e ligue-o.<br/><br/>"/>

		<task_p18_oldtv		value="Coloque as pilhas na caixa sob o toldo."/>

