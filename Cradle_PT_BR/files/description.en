		<task_p19_donor_overall		value="<font size=24 color=#D29B28>Brilho Residual</font><br/><br/>Ida está perdendo sua capacidade de se comunicar. Talvez substituir o sincronizador resolva o problema. Adquira um novo sincronizador.<br/><br/>"/>

		<task_p19_donor_complex 	value="Procure no sexto pavilhão."/>

		<task_magic_lakes_title		value="Pavilhão «Lagos Mágicos»"/>

		<task_magic_lakes		value="— Colete 30 cubos laranja para obter o sincronizador.<br/>
										— Arremesse cubos na corrente ascendente.<br/>
										— Use bombas para destruir blocos cinzas.<br/>
										— Aplique um cubo laranja em um vermelho para fazer a bomba explodir."/>

