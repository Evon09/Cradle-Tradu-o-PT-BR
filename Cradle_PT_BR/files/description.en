		<task_p23_ida_talk		value="Fale com Ida."/>

		<task_p24_reanimation_overall		value="<font size=24 color=#D29B28>Novo Começo</font><br/><br/>A neurocópia de Ida está destruída. Você pode trazer Ida de volta à razão direcionando uma descarga elétrica para o plexo nervoso em suas costas.<br/><br/>"/>

		<task_p24_reanimation_take_ida		value="Leve Ida para uma fonte poderosa de eletricidade."/>

		<task_p24_reanimation_fix_ida		value="Prenda Ida em posição vertical no centro do canteiro de flores arruinado."/>

		<task_p24_reanimation_electricity		value="Reanime Ida com um cabo elétrico."/>

		<tutorial_move		value="<font size=24 color=#D29B28>Movimento</font><br/><br/>Use W, A, S, D para se mover."/>

		<tutorial_run		value="<font size=24 color=#D29B28>Correr, Pular, Agachar</font><br/><br/>Segure SHIFT para correr. Pressione ESPAÇO para pular. Pressione e segure CTRL para agachar."/>

		<tutorial_read		value="<font size=24 color=#D29B28>Leitura</font><br/><br/>Certos objetos contêm texto. Para ler o texto do suporte de informações, aproxime-se dele e clique com o botão esquerdo no suporte quando o cursor mudar de forma."/>

		<tutorial_action		value="<font size=24 color=#D29B28>Ação</font><br/><br/>Clique com o botão esquerdo no portão para abri-lo."/>

		<tutorial_take		value="<font size=24 color=#D29B28>Pegar</font><br/><br/>Certos objetos podem ser pegos. Clique com o botão esquerdo no cubo vermelho para pegá-lo."/>

		<tutorial_inventory		value="<font size=24 color=#D29B28>Inventário</font><br/><br/>Use o inventário para carregar itens com você. Pressione E enquanto segura o cubo. Pressione E novamente para remover o item do inventário."/>

		<tutorial_apply		value="<font size=24 color=#D29B28>Usar</font><br/><br/>Você pode usar certos itens em outros. Enquanto segura o item A, passe o mouse sobre o item B e clique com o botão esquerdo nele. Adicione a peça que falta ao arranjo de cubos."/>

		<tutorial_throw		value="<font size=24 color=#D29B28>Arremessar</font><br/><br/>Clique com o botão direito para forçar o arremesso de um item segurado."/>

		<tutorial_prompt		value="<font size=24 color=#D29B28>Dica</font><br/><br/>Você pode ocasionalmente precisar de ajuda ao longo do jogo. Pressione TAB para receber uma dica. Pressione TAB novamente para escondê-la."/>

